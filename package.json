{
  "name": "mcp-eval-runner",
  "version": "1.0.0",
  "description": "A standardized testing harness for MCP servers and agent workflows",
  "author": "dbsectrainer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dbsectrainer/mcp-eval-runner.git"
  },
  "homepage": "https://github.com/dbsectrainer/mcp-eval-runner#readme",
  "type": "module",
  "bin": {
    "mcp-eval-runner": "./dist/index.js"
  },
  "files": [
    "dist",
    "evals",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    ".env.example"
  ],
  "keywords": [
    "mcp",
    "mcp-server",
    "testing",
    "evals"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "dev": "tsx src/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "lint": "eslint src tests",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "chokidar": "^5.0.0",
    "express": "^5.2.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^24.12.0",
    "@types/yargs": "^17.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0",
    "yargs": "^18.0.0"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
